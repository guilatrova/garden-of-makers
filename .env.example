# Garden of Makers Environment Variables

# TrustMRR API Configuration
# Get your API key from https://trustmrr.com
TRUSTMRR_API_KEY=tmrr_your_api_key_here

# Supabase Configuration
# Create a project at https://supabase.com
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# App Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Sync Secret (optional — protects POST /api/sync in production)
# SYNC_SECRET=your_random_secret_here
